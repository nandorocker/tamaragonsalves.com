---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutGalleryImage from '../../components/AboutGalleryImage.astro';
import BookCarouselCard from '../../components/BookCarouselCard.astro';
import VideoPublicationCard from '../../components/VideoPublicationCard.astro';
import Button from '../../components/Button.astro';
import OrcidIcon from '../../components/OrcidIcon.astro';
import { images } from '../../data/global';
import { loadAllTranslations, getTranslationSync, getStaticPaths } from '../../utils/i18n';
import type { Language } from '../../utils/i18n';
import galleryData from '../../data/gallery.json';
import booksData from '../../data/books.json';
import videosData from '../../data/videos.json';

export { getStaticPaths };

const { lang } = Astro.params;
const currentLang = (Astro.props.lang ?? lang ?? 'en') as Language;
const langPrefix = currentLang === 'en' ? '/en' : `/${currentLang}`;

// Load all translations (global + home page) for dynamic content
const allTranslations = await loadAllTranslations(currentLang, 'home');

// Load book translations specifically
const allContentTranslations = await loadAllTranslations(currentLang, 'books');
const bookTranslations = allContentTranslations.books || {};

// Helper function to get translation with fallback
const t = (key: string) => getTranslationSync(allTranslations, key);
---

<BaseLayout title={t('pageTitle')} pageTheme="yellow" isHomePage={true}>
	<!-- Hero Section -->
	<section id="home"
	    class="hero bg-gradient-yellow flex items-center w-full md:h-80vh min-h-[45rem] sm:min-h-[50rem] pt-32 md:pt-24 2xl:pt-48 pb-20 md:pb-0 overflow-hidden">
	    <div class="contain-wide section-margins-medium flex flex-col md:flex-row items-center gap-12 md:gap-16 lg:gap-24 max-w-lg md:max-w-none lg:max-w-4xl mx-auto" data-stagger>
			
			<!-- Left Column: Decorative Photo -->
			<div class="relative w-full md:w-1/4 flex justify-center" data-animate>
				<div class="relative">
					<!-- Red/Flamingo background box -->
					<div class="absolute -bottom-4 -left-4 md:-bottom-6 md:-left-6 lg:-bottom-8 lg:-left-8 w-[calc(100%+1rem)] h-[calc(100%+1rem)] md:w-[calc(100%+1.5rem)] md:h-[calc(100%+1.5rem)] lg:w-[calc(100%+2rem)] lg:h-[calc(100%+2rem)] bg-flamingo-700 rounded-lg"></div>
					<!-- Navy background box -->
					<div class="absolute -top-4 -right-4 md:-top-6 md:-right-6 lg:-top-8 lg:-right-8 w-[calc(100%+1rem)] h-[calc(100%+1rem)] md:w-[calc(100%+1.5rem)] md:h-[calc(100%+1.5rem)] lg:w-[calc(100%+2rem)] lg:h-[calc(100%+2rem)] bg-indigo-900 rounded-lg"></div>
					<!-- Photo -->
					<div class="relative z-10 overflow-hidden w-[160px] md:w-[200px] lg:w-[260px]">
						<img 
							src="/images/home_photo.png" 
							alt="Tamara Amoroso Gonsalves" 
							class="w-full h-auto object-contain"
						/>
					</div>
				</div>
			</div>

			<!-- Right Column: Content (3/4 Width) -->
	        <div class="w-full md:w-3/4 text-left max-md:text-center md:pb-4" data-stagger>
	            <h5 class="text-indigo-900 dark:text-indigo-300" data-animate>
					{getTranslationSync(allTranslations, 'heroSection.subtitle')}
				</h5>
	            <h1 class="text-indigo-900 dark:text-indigo-300" data-animate 
					set:html={getTranslationSync(allTranslations, 'heroSection.name').split(' ').map((w: string) => `<span class="inline md:block">${w}</span>`).join(' ')}>
				</h1>
	            <p class="bigger max-sm:hyphens-auto lg:max-w-2xl dark:text-gray-200 mb-0" data-animate 
					set:html={getTranslationSync(allTranslations, 'heroSection.description')}>
				</p>
	        </div>
	    </div>
	</section>


	<!-- Publications Preview Section -->
	<section id="publications-preview" class="contain-margins-y bg-soap-50 dark:bg-gray-700">
		<div class="contain-wide section-margins-medium">
			<h1 class="mb-8" data-animate>{t('publicationsHeading')}</h1>
			
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-lg mx-auto">
				<p class="mb-6 dark:text-gray-300" data-animate set:html={t('publicationsDescription')}>

				<h2 class="mb-6" data-animate>{t('publicationsBooksSubheading')}</h2>
				
				<!-- Book Carousel -->
				<div class="book-carousel relative" data-animate>
					<div class="carousel-outer-container py-4 relative">
						<div class="carousel-container overflow-hidden relative" style="clip-path: inset(0);">
							<div class="carousel-track flex transition-transform duration-500 ease-in-out">
								{booksData.map((book, index) => (
									<div class="carousel-slide w-full lg:w-1/2 flex-shrink-0">
										<div class={`${index < booksData.length - 1 ? 'mr-4 lg:mr-6' : ''}`}>
											<BookCarouselCard 
												book={book}
												bookTranslations={bookTranslations}
												lang={currentLang}
											/>
										</div>
									</div>
								))}
							</div>
						</div>
					</div>

					<!-- Previous Button -->
					<button 
						id="prev-book" 
						class="carousel-btn absolute left-0 md:-left-1 lg:-left-2 top-16 md:top-20 -translate-x-4 md:-translate-x-12 z-[5] p-3 rounded-full bg-pink-700 text-white hover:bg-pink-900 dark:bg-pink-300 dark:text-gray-900 dark:hover:bg-pink-100 transition-colors disabled:opacity-20 disabled:cursor-not-allowed shadow-lg"
						aria-label="Previous books"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
						</svg>
					</button>
					
					<!-- Next Button -->
					<button 
						id="next-book" 
						class="carousel-btn absolute right-0 md:-right-1 lg:-right-2 top-16 md:top-20 translate-x-4 md:translate-x-12 z-[5] p-3 rounded-full bg-pink-700 text-white hover:bg-pink-900 dark:bg-pink-300 dark:text-gray-900 dark:hover:bg-pink-100 transition-colors disabled:opacity-20 disabled:cursor-not-allowed shadow-lg"
						aria-label="Next books"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
						</svg>
					</button>
				</div>
				
				<div class="text-center mt-12" data-animate>
					<Button href={`${langPrefix}/publications`} variant="secondary" size="lg">{t('seeAllPublications')}</Button>
				</div>
			</div>
		</div>
	</section>

	<!-- Speaking Preview Section -->
	<section id="speaking-preview" class="contain-margins-y bg-white dark:bg-gray-800">
		<div class="contain-medium section-margins-medium">
			<h1 class="mb-6 dark:text-pink-300" data-animate><a href={`${langPrefix}/speaking`} class="hover:text-sky-700 dark:hover:text-sky-300 transition-colors">{t('speakingHeading')}</a></h1>
			
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-lg mx-auto">
				<p class="mb-8 dark:text-gray-300" data-animate>
					{t('speakingIntroStart')}<a href={`${langPrefix}/#contact-me`} class="font-semibold text-sky-700 dark:text-sky-300 hover:text-sky-900 dark:hover:text-sky-100">{t('speakingCTALink')}</a>{t('speakingIntroEnd')}
				</p>

				<div class="flex flex-col lg:flex-row lg:justify-between items-start lg:items-end gap-2 lg:gap-0 mb-6" data-animate>
					<h2 class="mb-0 dark:text-pink-300">{t('speakingTalksSubheading')}</h2>
					<a href={`${langPrefix}/speaking`} class="text-base font-semibold text-sky-700 dark:text-sky-300 hover:text-sky-900 dark:hover:text-sky-100 icon-after icon-arrow-right icon-space-sm whitespace-nowrap">
						{t('seeAllTalks')}
					</a>
				</div>
				<div class="video-grid mt-8" data-animate>
					{videosData.slice(0, 4).map(video => (
						<VideoPublicationCard 
							id={video.id}
							videoUrl={video.videoUrl}
							thumbnailUrl={video.thumbnailUrl}
							date={video.date}
							lang={currentLang}
						/>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section id="what-i-offer" class="contain-margins-y bg-violet-50 dark:bg-gray-700">
		<div class="contain-medium section-margins-medium">
			<h1 class="mb-8 dark:text-pink-300" data-animate>{t('servicesHeading')}</h1>
			
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-lg mx-auto">
				<p class="mb-8 dark:text-gray-300" data-animate>
					{t('servicesIntro')}
				</p>

				<div class="flex flex-col mb-12" data-stagger>
                    <div class="flex flex-col md:flex-row md:items-start md:gap-8 border-b border-gray-200 dark:border-gray-600 py-6 first:pt-0" data-animate>
                        <h3 class="md:w-1/4 mb-2 md:mb-0 dark:text-pink-300">{t('coursesTitle')}</h3>
                        <p class="md:w-3/4 mb-0 dark:text-gray-300">{t('coursesSummary')}</p>
                    </div>
                    <div class="flex flex-col md:flex-row md:items-start md:gap-8 border-b border-gray-200 dark:border-gray-600 py-6" data-animate>
                        <h3 class="md:w-1/4 mb-2 md:mb-0 dark:text-pink-300">{t('consultancyTitle')}</h3>
                        <p class="md:w-3/4 mb-0 dark:text-gray-300">{t('consultancySummary')}</p>
                    </div>
                    <div class="flex flex-col md:flex-row md:items-start md:gap-8 border-b border-gray-200 dark:border-gray-600 py-6" data-animate>
                        <h3 class="md:w-1/4 mb-2 md:mb-0 dark:text-pink-300">{t('lawyeringTitle')}</h3>
                        <p class="md:w-3/4 mb-0 dark:text-gray-300">{t('lawyeringSummary')}</p>
                    </div>
                    <div class="flex flex-col md:flex-row md:items-start md:gap-8 border-b border-gray-200 dark:border-gray-600 py-6" data-animate>
                        <h3 class="md:w-1/4 mb-2 md:mb-0 dark:text-pink-300">{t('mentorshipTitle')}</h3>
                        <p class="md:w-3/4 mb-0 dark:text-gray-300">{t('mentorshipSummary')}</p>
                    </div>
                    <div class="flex flex-col md:flex-row md:items-start md:gap-8 py-6 pb-0" data-animate>
                        <h3 class="md:w-1/4 mb-2 md:mb-0 dark:text-pink-300">{t('advocacyTitle')}</h3>
                        <p class="md:w-3/4 mb-0 dark:text-gray-300">{t('advocacySummary')}</p>
                    </div>
				</div>
				
				<div class="text-center mt-0" data-animate>
					<Button href={`${langPrefix}/services`} variant="secondary" size="lg">{t('seeAllServices')}</Button>
				</div>
			</div>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact-me" class="contain-margins-y bg-white dark:bg-gray-800">
		<div class="contain-medium section-margins-medium">
			<h1 class="dark:text-pink-300" data-animate>{t('contactHeading')}</h1>
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-md mx-auto mb-12" data-stagger>
			<p class="dark:text-gray-300" data-animate>{t('contactDescription')}</p>

			<p data-animate><Button id="email-link" href="#" size="lg" class="max-sm:block md:px-12 md:py-4 md:text-lg md:rounded-xl icon-before icon-comment-smile icon-space-sm">{t('contactEmailButtonText')}</Button>
			</p>				<h4 class="max-sm:text-center dark:text-pink-300" data-animate>{t('contactSocialMediaHeading')}</h4>
				<ul class="flex flex-row max-sm:justify-center items-start gap-8 max-sm:mt-8" data-animate>
					<li><a href="https://www.instagram.com/tamaramoroso" target="_blank" rel="noopener noreferrer"
							title="Threads"><img src={`${images}/social-instagram.svg`} class="w-12 hover-shift-sm dark:invert"
								alt="Instagram"></a>
					</li>
					<li><a href="https://www.linkedin.com/in/tamara-amoroso-gonsalves-941527229/" target="_blank"
							rel="noopener noreferrer" title="LinkedIn"><img src={`${images}/social-linkedin.svg`}
								class="w-12 hover-shift-sm dark:invert" alt="LinkedIn"></a>
					</li>
				</ul>
			</div>
		</div>
	</section>
</BaseLayout>
