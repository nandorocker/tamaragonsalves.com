---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutGalleryImage from '../../components/AboutGalleryImage.astro';
import Button from '../../components/Button.astro';
import { loadAllTranslations, getTranslationSync, getStaticPaths } from '../../utils/i18n';
import type { Language } from '../../utils/i18n';
import galleryData from '../../data/gallery.json';

export { getStaticPaths };

const { lang } = Astro.params;
const currentLang = lang as Language;

const allTranslations = await loadAllTranslations(currentLang, 'home');
const t = (key: string) => getTranslationSync(allTranslations, key);

// Custom gallery layout for the about page to avoid changing the home page
const aboutGalleryData = galleryData.slice(0, 4).map((image, index) => {
	// Make the bottom leftmost picture span only one row and crop it to match the adjacent picture
	if (index === 2) {
		return { ...image, gridClass: "", imgClass: "w-full h-full object-cover aspect-square" };
	}
	if (index === 3) {
		return { ...image, imgClass: "w-full h-full object-cover aspect-square" };
	}
	return image;
});
---

<BaseLayout title={t('aboutMeHeading')} pageTheme="yellow">
	<section id="about" class="pt-8 lg:pt-16 pb-8 lg:pb-12 mt-10 sm:mt-20">
		<div class="contain-medium section-margins-medium">
			<h1 data-animate>{t('aboutMeHeading')}</h1>
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-md mx-auto mb-16" data-stagger>
				<p data-animate>{t('aboutPageIntro')}</p>
			</div>
		</div>

		<div class="w-full contain-medium section-margins-medium" data-animate>
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
				<div class="lg:col-span-2 grid grid-cols-2 gap-4">
					{aboutGalleryData.map((image) => (
						<AboutGalleryImage 
							src={image.src}
							altKey={image.altKey}
							fslightboxGroup={image.fslightboxGroup}
							gridClass={image.gridClass}
							imgClass={(image as any).imgClass}
						/>
					))}
				</div>
				
				<div class="lg:col-span-3" data-stagger>
					<h2 data-animate class="mb-6">{t('aboutAcademicHeading')}</h2>
					<p data-animate>{t('aboutAcademicPara1')}</p>
					
					<p data-animate>{t('aboutAcademicPara2')}</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Advocacy & Reach Section -->
	<section id="advocacy" class="pb-8 lg:pb-16 mt-8 sm:mt-12">
	    <div class="contain-medium section-margins-medium" data-stagger>
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
				<div class="lg:col-span-2">
					<h1 class="max-lg:text-size-h2 max-lg:mb-0 dark:text-pink-300" data-animate>{t('aboutAdvocacyHeading')}</h1>
				</div>
				<div class="lg:col-span-3">
					<p class="dark:text-gray-300" data-animate>{t('aboutAdvocacyPara1')}</p>
					<p class="dark:text-gray-300" data-animate>{t('aboutAdvocacyPara2')}</p>
				</div>
			</div>
	    </div>
	</section>

	<!-- Continue the Conversation Section -->
	<section id="conclusion" class="pb-16 lg:pb-36 mt-20 sm:mt-32">
	    <div class="contain-medium px-5">
			<div class="bg-mustard-100 dark:bg-gray-800 rounded-3xl max-w-4xl mx-auto flex flex-col md:flex-row items-end relative shadow-sm" data-animate>
				<!-- Left overlapping image -->
				<div class="w-full md:w-5/12 px-6 md:px-0 md:pl-8 -mt-16 md:-mt-12 md:-mb-6 flex justify-center z-10">
					<img 
						src="/images/tamara_paete.jpg" 
						alt="Tamara Amoroso Gonsalves" 
						class="w-full max-w-sm h-auto object-cover rounded-2xl shadow-xl saturate-[0.95]"
					/>
				</div>
				<!-- Right paragraph body -->
				<div class="w-full md:w-7/12 p-8 md:p-12 lg:p-16 text-left self-center">
					<p class="text-gray-900 dark:text-gray-200 leading-relaxed max-md:text-center md:text-lg mb-0">
						{t('aboutConclusionPara1')}<a href={t('cvUrl')} target="_blank" class="font-bold border-b border-gray-900/40 dark:border-white/40 hover:text-pink-600 transition-colors">{t('aboutConclusionLinkText')}</a>{t('aboutConclusionPara2')}
					</p>
				</div>
			</div>
	    </div>
	</section>
</BaseLayout>

