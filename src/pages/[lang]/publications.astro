---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookCard from '../../components/BookCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ArticleModal from '../../components/ArticleModal.astro';
import DownloadModal from '../../components/DownloadModal.astro';
import ProjectCardHorizontal from '../../components/ProjectCardHorizontal.astro';
import Button from '../../components/Button.astro';
import OrcidIcon from '../../components/OrcidIcon.astro';
import DevPanel from '../../components/DevPanel.astro';
import { loadAllTranslations, getTranslationSync, getStaticPaths } from '../../utils/i18n';
import type { Language } from '../../utils/i18n';
import booksData from '../../data/books.json';
import projectsData from '../../data/projects.json';
import articlesData from '../../data/articles.json';

export { getStaticPaths };

const { lang } = Astro.params;
const currentLang = (Astro.props.lang ?? lang ?? 'en') as Language;

// Load all translations (global + home page) for dynamic content
const allTranslations = await loadAllTranslations(currentLang, 'home');

// Load book translations specifically
const allContentTranslations = await loadAllTranslations(currentLang, 'books');
const bookTranslations = allContentTranslations.books || {};

// Load article translations
const allArticleTranslations = await loadAllTranslations(currentLang, 'articles');
const articleTranslations = allArticleTranslations.articles || {};

// Helper function to get translation with fallback
const t = (key: string) => getTranslationSync(allTranslations, key);
---

<BaseLayout title={t('publicationsHeading')} pageTheme="soap">
	<section id="publications" class="contain-margins-y bg-soap-50 dark:bg-gray-700 mt-10 sm:mt-20">
	    <div class="contain-wide section-margins-medium">
	        <h1 data-animate>{t('publicationsHeading')}</h1>
	        <div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-md mx-auto" data-stagger>
	            <p data-animate>{t('publicationsDescription')}</p>

	            <div class="flex flex-col sm:flex-row sm:items-center gap-4 mt-2 mb-8" data-animate>
                <Button href={t('cvUrl')} variant="secondary" icon="icon-file-pdf" class="mb-0">
                    {t('cvLinkText')}
                </Button>
                <Button href={t('publicationsOrcidUrl')} variant="secondary" target="_blank" class="mb-0">
                    <OrcidIcon slot="icon-before" class="w-4 h-4 mr-2" size="16" color1="currentColor" color2="#FFFFFF" />
                    {t('publicationsOrcidLinkText')}
                </Button>
            </div>

	            </div>
	        </div>

			<div class="contain-medium px-5 md:px-12 mt-16">
				<h2 data-animate>{t('publicationsBooksSubheading')}</h2>
				<div class="book-grid mt-6" data-stagger>
					{booksData.map(book => (
						<div data-animate>
							<BookCard
								book={book}
								bookTranslations={bookTranslations}
								lang={currentLang}
							/>
						</div>
					))}
				</div>
			</div>

			<div class="contain-medium px-5 md:px-12 mt-16">
				<h2 data-animate>{t('publicationsArticlesSubheading')}</h2>

				<div class="publication-filter-strip -mx-5 px-5 md:mx-0 md:px-0 mt-6 mb-8" data-animate role="group">
					<button class="article-filter-btn active" data-filter="all">{articleTranslations.filterAll}</button>
					{(() => {
						const themes = [...new Set(articlesData.map(a => a.theme))];
						const themeLabels = articleTranslations.themeLabels || {};
						return themes.map(theme => (
							<button class="article-filter-btn" data-filter={theme}>{themeLabels[theme] || theme}</button>
						));
					})()}
				</div>

				<div id="article-list" class="article-grid" data-animate>
					{articlesData.map(article => (
						<div data-theme={article.theme}>
							<ArticleCard
								article={article}
								articleTranslations={articleTranslations}
								lang={currentLang}
								publicationLabel={t('publicationLabel')}
							/>
						</div>
					))}
				</div>

			<ArticleModal
				articles={articlesData}
				articleTranslations={articleTranslations}
				lang={currentLang}
				publicationLabel={t('publicationLabel')}
			/>

			<DownloadModal
				articles={articlesData}
				lang={currentLang}
			/>

			<div id="modal-overlay" class="modal-overlay" aria-hidden="true"></div>
			</div>

			<div class="contain-medium px-5 md:px-12 mt-16">
				<h2 data-animate>{t('publicationsOtherProjectsSubheading')}</h2>
				<div class="project-grid mt-6" data-stagger>
					{projectsData.map(project => (
						<div data-animate>
							<ProjectCardHorizontal
								id={project.id}
								imageUrl={project.imageUrl}
								linkUrl={project.linkUrl}
								linkIcon={project.linkIcon}
								lang={currentLang}
							/>
						</div>
					))}
				</div>
			</div>
	    </div>
	</section>
	<DevPanel />
</BaseLayout>

<script>
function autoTriggerDownload() {
  const params = new URLSearchParams(window.location.search);
  const articleId = params.get('download');
  if (!articleId) return;

  const cleanUrl = window.location.pathname + window.location.hash;
  window.history.replaceState({}, document.title, cleanUrl);

  setTimeout(() => {
    window.requestDownload?.(articleId);
  }, 300);
}

autoTriggerDownload();
document.addEventListener('astro:page-load', autoTriggerDownload);
</script>

<style>
  .publication-filter-strip {
    @apply flex gap-2 overflow-x-auto;
    scrollbar-width: none;
  }

  .publication-filter-strip::-webkit-scrollbar {
    display: none;
  }

  .article-filter-btn {
    @apply flex-none whitespace-nowrap px-4 py-1.5 rounded-full text-sm font-semibold
           text-gray-600 dark:text-gray-300 bg-transparent
           hover:text-[#4a2083] dark:hover:text-violet-200
           sm:border sm:border-gray-300 sm:dark:border-gray-600
           sm:hover:border-[#4a2083] sm:dark:hover:border-violet-200
           transition-colors duration-150 cursor-pointer;
  }

  .article-filter-btn.active {
    @apply text-white sm:border dark:text-gray-800;
    background-color: #4a2083;
    border-color: #4a2083;
  }
</style>

<script>
function initArticleFilters() {
  var items = Array.from(document.querySelectorAll('#article-list > [data-theme]'));
  var filterBtns = Array.from(document.querySelectorAll('.article-filter-btn'));

  var activeFilter = 'all';

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      activeFilter = btn.getAttribute('data-filter') || 'all';
      filterBtns.forEach(function (b) { b.classList.toggle('active', b === btn); });

      items.forEach(function (item) {
        var theme = item.getAttribute('data-theme') || '';
        var visible = activeFilter === 'all' || theme === activeFilter;
        item.style.display = visible ? '' : 'none';
      });
    });
  });
}

initArticleFilters();
document.addEventListener('astro:page-load', initArticleFilters);
</script>
