---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoPublicationCard from '../../components/VideoPublicationCard.astro';
import Button from '../../components/Button.astro';
import { loadAllTranslations, getTranslationSync, getStaticPaths } from '../../utils/i18n';
import type { Language } from '../../utils/i18n';
import videosData from '../../data/videos.json';

export { getStaticPaths };

const { lang } = Astro.params;
const currentLang = (Astro.props.lang ?? lang ?? 'en') as Language;
const langPrefix = currentLang === 'en' ? '/en' : `/${currentLang}`;

const allTranslations = await loadAllTranslations(currentLang, 'home');
const t = (key: string) => getTranslationSync(allTranslations, key);
---

<BaseLayout title={t('speakingHeading')} pageTheme="white">
	<section id="speaking" class="contain-margins-y bg-white dark:bg-gray-800 mt-10 sm:mt-20">
		<div class="contain-medium section-margins-medium">
			<h1 data-animate>{t('speakingHeading')}</h1>
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-md mx-auto mb-12" data-stagger>
				<p class="small" data-animate>{t('speakingDescription')}</p>
				<p data-animate><Button href={`${langPrefix}/#contact-me`} size="lg" class="icon-before icon-comment-smile icon-space-sm">{t('speakingContactButtonText')}</Button></p>
			</div>
		</div>

		<!-- Videos heading + Filter + Search -->
		<div class="contain-medium px-5 md:px-12 mb-8" data-animate>
			<h2 class="text-size-h3">{t('speakingVideosHeading')}</h2>
		</div>
		<div class="contain-medium px-5 md:px-12 mb-10 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between" data-animate>
			<div class="flex flex-wrap gap-1 sm:gap-8 items-center">
				<div class="flex items-center gap-1 sm:gap-2">
					<span class="hidden sm:inline text-sm font-semibold text-gray-500 dark:text-gray-400">{t('filterTopic')}:</span>
					<div class="video-filter-buttons" role="group">
						<button class="video-filter-btn active" data-filter="all">{t('filterAll')}</button>
						<button class="video-filter-btn" data-filter="advocacy">{t('filterAdvocacy')}</button>
						<button class="video-filter-btn" data-filter="academic">{t('filterAcademic')}</button>
					</div>
				</div>
				<div class="flex items-center gap-1 sm:gap-2">
					<span class="hidden sm:inline text-sm font-semibold text-gray-500 dark:text-gray-400">{t('filterLanguage')}:</span>
					<div class="video-filter-buttons" role="group" aria-label={t('filterLanguage')}>
						<button class="video-lang-btn active" data-lang="all">{t('filterAll')}</button>
						<button class="video-lang-btn" data-lang="EN">EN</button>
						<button class="video-lang-btn" data-lang="PT">PT</button>
					</div>
				</div>
			</div>
			<input
				type="search"
				id="video-search"
				class="video-search-input"
				placeholder={t('searchPlaceholder')}
				aria-label={t('searchPlaceholder')}
			/>
		</div>

		<!-- No results message -->
		<p id="video-no-results" class="hidden contain-medium px-5 md:px-12 text-gray-500 dark:text-gray-400 mb-10">
			{t('noResults')}
		</p>

		<!-- Flat video grid -->
		<div class="contain-medium px-5 md:px-12">
			<div class="video-grid">
				{videosData.map(video => (
				<VideoPublicationCard
					id={video.id}
					videoUrl={video.videoUrl}
					thumbnailUrl={video.thumbnailUrl}
					date={video.date}
					lang={currentLang}
					category={video.category}
					language={video.language}
				/>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<script>
function initFilters() {
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.video-card'));
  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.video-filter-btn[data-filter]'));
  const langBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.video-lang-btn[data-lang]'));
  const searchInput = document.getElementById('video-search') as HTMLInputElement | null;
  const noResults = document.getElementById('video-no-results');

  let activeFilter = 'all';
  let activeLang = 'all';
  let searchQuery = '';

  function applyFilters() {
    const q = searchQuery.toLowerCase();
    let visibleCount = 0;

    cards.forEach(card => {
      const category = card.dataset.category ?? '';
      const lang = card.dataset.language ?? '';
      const searchText = (card.dataset.searchtext ?? '').toLowerCase();
      const matchesFilter = activeFilter === 'all' || category === activeFilter;
      const matchesLang = activeLang === 'all' || lang === activeLang;
      const matchesSearch = !q || searchText.includes(q);
      const visible = matchesFilter && matchesLang && matchesSearch;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    if (noResults) noResults.classList.toggle('hidden', visibleCount > 0);
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter ?? 'all';
      filterBtns.forEach(b => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  langBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeLang = btn.dataset.lang ?? 'all';
      langBtns.forEach(b => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value;
    applyFilters();
  });
}

initFilters();
document.addEventListener('astro:page-load', initFilters);
</script>
