---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { loadAllTranslations, getTranslationSync, getStaticPaths } from '../../utils/i18n';
import type { Language } from '../../utils/i18n';
import { images } from '../../data/global';

export { getStaticPaths };

const { lang } = Astro.params;
const currentLang = (Astro.props.lang ?? lang ?? 'en') as Language;

const allTranslations = await loadAllTranslations(currentLang, 'home');
const t = (key: string) => getTranslationSync(allTranslations, key);
---

<BaseLayout title={t('contactPageTitle')} pageTheme="white">
	<section id="contact" class="contain-margins-y bg-white dark:bg-gray-800 mt-10 sm:mt-20">
		<div class="contain-medium section-margins-medium">
			<h1 class="dark:text-pink-300" data-animate>{t('contactHeading')}</h1>
			<div class="sm:max-w-[560px] md:max-w-screen-sm lg:max-w-screen-lg mx-auto">
				<p class="mb-8 dark:text-gray-300 max-w-prose" data-animate>{t('contactDescription')}</p>

				<div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-12 lg:gap-16 items-start">
					<div data-animate>
						<ContactForm lang={currentLang} />
					</div>

					<aside class="lg:w-64 shrink-0" data-animate>
						<h4 class="dark:text-pink-300 mb-3">{t('contactSocialMediaHeading')}</h4>
						<ul class="flex flex-row lg:flex-col items-start gap-4">
							<li>
								<a href="https://www.instagram.com/tamaramoroso" target="_blank" rel="noopener noreferrer" title="Instagram" class="flex items-center gap-3 group">
									<img src={`${images}/social-instagram.svg`} class="w-10 hover-shift-sm dark:invert" alt="Instagram">
									<span class="text-lg font-medium text-gray-600 dark:text-gray-300 group-hover:text-pink-700 dark:group-hover:text-pink-300 transition-colors hidden lg:inline">Instagram</span>
								</a>
							</li>
							<li>
								<a href="https://www.linkedin.com/in/tamara-amoroso-gonsalves-941527229/" target="_blank" rel="noopener noreferrer" title="LinkedIn" class="flex items-center gap-3 group">
									<img src={`${images}/social-linkedin.svg`} class="w-10 hover-shift-sm dark:invert" alt="LinkedIn">
									<span class="text-lg font-medium text-gray-600 dark:text-gray-300 group-hover:text-pink-700 dark:group-hover:text-pink-300 transition-colors hidden lg:inline">LinkedIn</span>
								</a>
							</li>
						</ul>
					</aside>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
