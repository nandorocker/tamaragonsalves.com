---
import { Image } from 'astro:assets';
import imageMap from '../assets/imageMap';
import { loadAllTranslations, getTranslationSync } from '../utils/i18n';
import type { Language } from '../utils/i18n';

export interface Props {
  id: string;
  videoUrl: string;
  thumbnailUrl: string;
  date: string;
  lang: Language;
  category?: string;
  language?: string;
}

const { 
  id,
  videoUrl,
  thumbnailUrl,
  date,
  lang,
  category = '',
  language = ''
} = Astro.props;

// Load all translations (global + home page) for the current language
const translations = await loadAllTranslations(lang, 'home');

// Get title and description from translations using the video ID
const title = getTranslationSync(translations, `videos.${id}.title`) || `[videos.${id}.title]`;
const description = getTranslationSync(translations, `videos.${id}.description`) || `[videos.${id}.description]`;
const linkText = getTranslationSync(translations, "watchOnSite");

// Get localized aria/alt strings
const watchVideoLabel = getTranslationSync(translations, 'watchVideoAria').replace('{title}', title);
const videoThumbnailAltText = getTranslationSync(translations, 'videoThumbnailAlt').replace('{title}', title);
const formattedDate = new Date(date).toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});

// Look up image from manifest
const img = thumbnailUrl ? imageMap[thumbnailUrl] : null;
if (thumbnailUrl && !img) throw new Error(`Missing image for video: ${thumbnailUrl}`);
---

<div class="video-card" data-category={category} data-language={language} data-searchtext={`${title} ${description}`}>
  <a href={videoUrl} target="_blank" aria-label={watchVideoLabel} rel="noopener noreferrer">
    <div class="video-thumbnail-container">
      {img
        ? <Image
            src={img}
            alt={videoThumbnailAltText}
            inferSize
            widths={[240, 480, 720]}
            sizes="(min-width: 768px) 320px, 100vw"
            format="webp"
            quality={90}
            loading="lazy"
          />
        : <div class="video-thumbnail-placeholder" aria-hidden="true"></div>
      }
    </div>
  </a>
  <div class="flex gap-2 items-center">
    <time datetime={date} class="video-date">{formattedDate}</time>
    {language && <span class="video-lang">{language}</span>}
  </div>
  <a href={videoUrl} class="not-italic no-underline" target="_blank" aria-label={watchVideoLabel} rel="noopener noreferrer">
    <h5 class="video-title">{title}</h5>
  </a>
  {description && <p class="video-description">{description}</p>}
  <a href={videoUrl} target="_blank" 
     class="video-link icon-after icon-external-link icon-space-sm"
     rel="noopener noreferrer">
    {linkText}
  </a>
</div>