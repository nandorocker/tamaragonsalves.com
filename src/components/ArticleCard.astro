---
import { Image } from 'astro:assets';
import imageMap from '../assets/imageMap';
import type { Language } from '../utils/i18n';
import { useTranslations } from '../utils/i18n';

const { article, articleTranslations, lang, publicationLabel } = Astro.props;
type ArticleData = Record<string, { title?: string; summary?: string; publicationInfo?: string; }>;
const articleData = (articleTranslations as ArticleData)[article.id] || {};
const t = useTranslations(lang as Language);
const title = articleData.title || article.id;
const img = article.image ? imageMap[article.image] : null;
if (article.image && !img) throw new Error(`Missing image for article: ${article.image}`);
const modalId = `modal-${article.id}`;
const linkLabels = articleTranslations.linkLabels || {};
const hasLinks = article.links && article.links.length > 0;
const hasFile = !!article.file;
---

<article
  class="bg-white dark:bg-gray-800 rounded-lg shadow-sm px-5 pt-5 pb-5 hover-shift-sm article-card h-full flex flex-col cursor-pointer"
  data-article
  data-open-modal={modalId}
>
  <div class="flex gap-3 sm:gap-4 items-start xl:block">
    {img ? (
      <Image
        src={img}
        alt=""
        inferSize
        widths={[160, 320, 480]}
        sizes="(min-width: 1280px) 280px, (min-width: 640px) 80px, 64px"
        format="webp"
        quality={90}
        loading="lazy"
        class="w-16 sm:w-20 h-16 sm:h-20 rounded-md object-cover flex-shrink-0 xl:w-full xl:h-40 xl:mb-4"
      />
    ) : (
      <div class="w-16 sm:w-20 h-16 sm:h-20 rounded-md flex-shrink-0 bg-gray-100 dark:bg-gray-700 flex items-center justify-center xl:w-full xl:h-40 xl:mb-4" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 4h15l9 9v23a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" />
          <path d="M23 4v9h9" />
          <path d="M12 20h16" />
          <path d="M12 26h16" />
          <path d="M12 32h10" />
        </svg>
      </div>
    )}
    <div class="flex-1 min-w-0">
      <h4 class="text-size-h6 mb-1">{title}</h4>
      <p class="mb-1 text-gray-600 dark:text-gray-400">
        <em>{article.author}</em>
      </p>
      <p class="mb-0 text-gray-500 dark:text-gray-400">
        {publicationLabel && <span class="font-semibold">{publicationLabel} </span>}
        <span set:html={articleData.publicationInfo || article.publicationInfo} />
      </p>
    </div>
  </div>

  <div class={`mt-auto pt-4 flex ${hasLinks ? 'flex-col gap-2' : 'flex-wrap gap-3'}`}>
    {hasLinks && article.links.map(link => {
      const label = linkLabels[link.labelKey] || link.label || link.url;
      return (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-base font-semibold text-pink-700 dark:text-pink-300 hover:text-pink-900 dark:hover:text-pink-100 flex items-center gap-1"
          onclick="event.stopPropagation()"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
          </svg>
          {label}
        </a>
      );
    })}
    {hasFile && !hasLinks && (
      <button
        type="button"
        class="download-excerpt-btn text-base font-semibold text-pink-700 dark:text-pink-300 hover:text-pink-900 dark:hover:text-pink-100 flex items-center gap-1"
        data-download-article={article.id}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path d="M10.75 2.75a.75.75 0 00-1.5 0v8.614L6.295 8.235a.75.75 0 10-1.09 1.03l4.25 4.5a.75.75 0 001.09 0l4.25-4.5a.75.75 0 00-1.09-1.03l-2.955 3.129V2.75z" />
          <path d="M3.5 12.75a.75.75 0 00-1.5 0v2.5A2.75 2.75 0 004.75 18h10.5A2.75 2.75 0 0018 15.25v-2.5a.75.75 0 00-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H4.75c-.69 0-1.25-.56-1.25-1.25v-2.5z" />
        </svg>
        {t('downloadExcerpt')}
      </button>
    )}
  </div>
</article>

<script>
window.requestDownload = async function(articleId) {
  try {
    const statusResponse = await fetch('/api/download-status', { cache: 'no-store' });
    const statusData = await statusResponse.json().catch(() => ({ ok: false }));
    if (statusResponse.ok && statusData?.ok === true) {
      const lang = document.documentElement.lang || 'en';
      const downloadUrl = `/api/download?articleId=${encodeURIComponent(articleId)}&lang=${encodeURIComponent(lang)}`;

      try {
        const response = await fetch(downloadUrl);
        const contentType = response.headers.get('content-type') || '';
        if (response.ok && contentType.includes('application/pdf')) {
          const blob = await response.blob();
          const url = URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.href = url;
          const filename = decodeURIComponent(response.url.split('/').pop() || 'download.pdf');
          link.download = filename;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
          setTimeout(() => URL.revokeObjectURL(url), 1000);
          return;
        }
      } catch {}

      window.location.href = downloadUrl;
      return;
    }
  } catch {}

  window.openDownloadModal?.(articleId);
};

function initDownloadButtons() {
  document.querySelectorAll('[data-download-article]').forEach(btn => {
    if (btn.dataset.downloadInitialized === 'true') return;
    btn.dataset.downloadInitialized = 'true';
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const articleId = btn.getAttribute('data-download-article');
      window.requestDownload?.(articleId);
    });
  });
}

initDownloadButtons();
document.addEventListener('astro:page-load', initDownloadButtons);
</script>
