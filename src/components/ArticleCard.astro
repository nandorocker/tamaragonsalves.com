---
import DropdownButton from './DropdownButton.astro';
import type { Language } from '../utils/i18n';
import { useTranslations } from '../utils/i18n';
import { images } from '../data/global';

const { article, articleTranslations, lang, publicationLabel } = Astro.props;
type ArticleData = Record<string, { title?: string; summary?: string; publicationInfo?: string; }>;
const articleData = (articleTranslations as ArticleData)[article.id] || {};
const t = useTranslations(lang as Language);
const title = articleData.title || article.id;
const summary = articleData.summary || '';
const hasLinks = article.links && article.links.length > 0;
const linkLabels = articleTranslations.linkLabels || {};
const thumbnailUrl = article.image ? `${images}/${article.image}` : null;
---

<article
  class="bg-white dark:bg-gray-800 rounded-lg shadow-sm px-5 pt-5 mb-4 transition-shadow hover:shadow-md"
  data-article
>
  <div class="flex gap-3 sm:gap-4 items-start mb-2">
    {thumbnailUrl ? (
      <img src={thumbnailUrl} alt="" class="w-16 sm:w-20 h-16 sm:h-20 rounded-md object-cover flex-shrink-0" loading="lazy">
    ) : (
      <div class="w-16 sm:w-20 h-16 sm:h-20 rounded-md flex-shrink-0 bg-gray-100 dark:bg-gray-700 flex items-center justify-center" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-6 h-6 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 4h15l9 9v23a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z" />
          <path d="M23 4v9h9" />
          <path d="M12 20h16" />
          <path d="M12 26h16" />
          <path d="M12 32h10" />
        </svg>
      </div>
    )}
    <div class="flex-1 min-w-0">
      <h4 class="text-size-h5 mb-1">{title}</h4>
      <p class="mb-1 text-gray-600 dark:text-gray-400">
        <em>{article.author}</em>
      </p>
      <p class="mb-0 text-gray-500 dark:text-gray-400">
        {publicationLabel && <span class="font-semibold">{publicationLabel} </span>}
        <span set:html={articleData.publicationInfo || article.publicationInfo} />
      </p>
    </div>
  </div>

  <div style="display:none" class="mt-3" data-expanded>
    <p class="text-gray-700 dark:text-gray-300">{summary}</p>
  </div>

  {hasLinks && (
    <div style="display:none" class="mt-3" data-links-wrapper>
      <DropdownButton
        icon="icon-external-link"
        label={t('readDownload')}
        links={article.links}
        linkLabels={linkLabels}
      />
    </div>
  )}

  <div class="text-center py-2 border-t border-gray-100 dark:border-gray-700" data-toggle-area>
    <button
      class="more-btn text-sm font-medium text-pink-600 dark:text-pink-400 hover:underline"
      data-toggle-btn type="button"
    >
      <span data-more-text><span class="read-more-arrow" aria-hidden="true">▾</span> {articleTranslations.expand}</span>
      <span style="display:none" data-less-text><span class="read-more-arrow" aria-hidden="true">▾</span> {articleTranslations.collapse}</span>
    </button>
  </div>
</article>

<script>
function initArticleCards() {
  var articles = document.querySelectorAll('article[data-article]');

  articles.forEach(function (article) {
    if (article.hasAttribute('data-article-initialized')) return;
    article.setAttribute('data-article-initialized', 'true');

    var toggleBtn = article.querySelector('[data-toggle-btn]');
    var toggleArea = article.querySelector('[data-toggle-area]');
    var moreText = article.querySelector('[data-more-text]');
    var lessText = article.querySelector('[data-less-text]');
    var expanded = article.querySelector('[data-expanded]');
    var linksWrapper = article.querySelector('[data-links-wrapper]');

    if (!toggleBtn || !expanded || !moreText || !lessText) return;

    function expand() {
      if (expanded.style.display !== 'none') return;
      article.dataset.state = 'expanded';
      expanded.style.display = '';
      if (linksWrapper) linksWrapper.style.display = '';
      moreText.style.display = 'none';
      lessText.style.display = '';
    }

    function collapse() {
      delete article.dataset.state;
      expanded.style.display = 'none';
      if (linksWrapper) linksWrapper.style.display = 'none';
      moreText.style.display = '';
      lessText.style.display = 'none';
    }

    function toggle() {
      if (expanded.style.display !== 'none') {
        collapse();
      } else {
        expand();
      }
    }

    toggleArea?.addEventListener('click', function (e) {
      e.stopPropagation();
      toggle();
    });
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initArticleCards);
} else {
  initArticleCards();
}

document.addEventListener('astro:page-load', initArticleCards);
</script>

<style>
  [data-toggle-area] {
    cursor: pointer;
  }
  .read-more-arrow {
    display: inline-block;
    transition: transform 0.35s ease;
  }
  [data-less-text] .read-more-arrow {
    transform: rotate(180deg);
  }
</style>
