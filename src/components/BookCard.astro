---
import { Image, getImage } from 'astro:assets';
import imageMap from '../assets/imageMap';
import type { Language } from '../utils/i18n';
import { useTranslations } from '../utils/i18n';
import DropdownButton from './DropdownButton.astro';

interface LinkGroup {
  type: string;
  links: Array<{
    labelKey: string;
    url: string;
  }>;
}

interface Book {
  id: string;
  author: string;
  imageUrl: string;
  linkGroups: LinkGroup[];
}

export interface Props {
  book: Book;
  bookTranslations: any;
  lang: Language;
}

const { book, bookTranslations, lang } = Astro.props;

const bookData = bookTranslations[book.id] || {};
const linkGroupTitles = bookTranslations.linkGroupTitles || {};
const linkLabels = bookTranslations.linkLabels || {};

const t = useTranslations(lang);

const downloadLinks = book.linkGroups.find(g => g.type === 'download')?.links || [];
const purchaseLinks = book.linkGroups.find(g => g.type === 'purchase')?.links || [];
const interviewLinks = book.linkGroups.find(g => g.type === 'interview')?.links || [];

const readDownloadLinks = [...downloadLinks, ...purchaseLinks];

const getTitleUrl = (): string | null => {
  if (readDownloadLinks.length > 0) {
    return readDownloadLinks[0].url;
  }
  return null;
};

const titleUrl = getTitleUrl();

const img = imageMap[book.imageUrl];
if (!img) throw new Error(`Missing image for book: ${book.imageUrl}`);

const lightboxWidth = Math.min(1200, img.width || 1200);
const lightboxImg = await getImage({
  src: img,
  format: 'webp',
  width: lightboxWidth,
  quality: 92,
});
---

<article class="book-item">
  <a data-fslightbox="books" href={lightboxImg.src} class="book-cover-link hover-shift-sm">
    <Image
      src={img}
      alt={bookData.imageAlt || 'Book cover'}
      inferSize
      widths={[160, 320, 480]}
      sizes="(min-width: 768px) 160px, 128px"
      format="webp"
      quality={90}
      loading="lazy"
      class="book-image"
    />
  </a>

  <div class="book-info">
    <div>
      <h5 class="mb-0 book-title">
        {titleUrl ? (
          <a href={titleUrl} target="_blank">{bookData.title}</a>
        ) : (
          bookData.title
        )}
      </h5>
      <p class="mb-3 dark:text-gray-300"><em>{book.author}</em></p>
    </div>
    <div class="book-description-wrapper dark:text-gray-300" data-full-text={bookData.description}>
      <div class="caption-container" data-caption>
        <span data-preview-text>{bookData.description}</span>
        <span style="display:none" data-full-part>{bookData.description}</span>
        <button
          class="more-btn inline text-sm font-medium text-pink-600 dark:text-pink-400 hover:underline"
          data-more-btn type="button"
          style="display:none"
        >
          <span class="read-more-arrow" aria-hidden="true">▾</span>
          <span>{bookTranslations.readMore}</span>
        </button>
      </div>
      <button
        class="show-less-btn text-sm font-medium text-pink-600 dark:text-pink-400 hover:underline mt-1"
        data-show-less-btn type="button"
        style="display:none"
      >
        <span class="read-more-arrow" aria-hidden="true">▾</span>
        <span>{bookTranslations.showLess}</span>
      </button>
    </div>

    <div class="flex flex-wrap gap-3 mt-3">
      {readDownloadLinks.length > 0 && (
        <DropdownButton
          icon="icon-file-pdf"
          label={t('readDownload')}
          links={readDownloadLinks}
          linkLabels={linkLabels}
        />
      )}

      {interviewLinks.length > 0 && (
        <DropdownButton
          icon="icon-video"
          label={t('interviews')}
          links={interviewLinks}
          linkLabels={linkLabels}
        />
      )}
    </div>
  </div>
</article>

<style>
  .read-more-arrow {
    display: inline-block;
    transition: transform 0.35s ease;
  }

  .show-less-btn .read-more-arrow {
    transform: rotate(180deg);
  }
</style>

<script>
function initBookDescriptions() {
  var MORE = '... more';

  function createMeasurer() {
    var el = document.createElement('div');
    el.style.position = 'absolute';
    el.style.visibility = 'hidden';
    el.style.left = '-9999px';
    el.style.top = '0';
    el.style.overflow = 'hidden';
    el.style.whiteSpace = 'pre-wrap';
    el.style.wordBreak = 'break-word';
    document.body.appendChild(el);
    return el;
  }

  function getLineHeightPx(el) {
    var lh = getComputedStyle(el).lineHeight;
    var parsed = parseFloat(lh);
    if (!isNaN(parsed) && parsed > 0) return parsed;
    return parseFloat(getComputedStyle(el).fontSize) * 1.35;
  }

  function computePreview(text, measurer, width, fontStyles) {
    measurer.style.width = width + 'px';
    for (var k in fontStyles) {
      if (fontStyles.hasOwnProperty(k)) measurer.style[k] = fontStyles[k];
    }

    var lh = getLineHeightPx(measurer);
    var maxH = lh * 4;

    var nlIdx = text.search(/\r?\n/);
    if (nlIdx !== -1) {
      var firstPara = text.slice(0, nlIdx).trimEnd();
      if (firstPara.length > 0) {
        measurer.textContent = firstPara;
        if (measurer.scrollHeight <= maxH) {
          return { preview: firstPara, needsMore: true };
        }
      }
    }

    measurer.textContent = text;
    if (measurer.scrollHeight <= maxH) {
      return { preview: text, needsMore: false };
    }

    var low = 0;
    var high = text.length;
    var best = '';

    while (low <= high) {
      var mid = Math.floor((low + high) / 2);
      var candidate = text.slice(0, mid).trimEnd() + ' ' + MORE;
      measurer.textContent = candidate;
      if (measurer.scrollHeight <= maxH) {
        best = text.slice(0, mid).trimEnd();
        low = mid + 1;
      } else {
        high = mid - 1;
      }
    }

    if (best.length < 10) {
      return { preview: text, needsMore: false };
    }

    best = best.trimEnd();
    var lastSpace = best.lastIndexOf(' ');
    if (lastSpace > 0 && best.length - lastSpace <= 20) {
      best = best.slice(0, lastSpace);
    }

    return { preview: best, needsMore: true };
  }

  var measurer = createMeasurer();
  var wrappers = document.querySelectorAll('.book-description-wrapper');

  wrappers.forEach(function (wrapper) {
    if (wrapper.hasAttribute('data-book-description-initialized')) return;
    wrapper.setAttribute('data-book-description-initialized', 'true');

    var fullText = wrapper.getAttribute('data-full-text') || '';
    var caption = wrapper.querySelector('[data-caption]');
    var previewText = wrapper.querySelector('[data-preview-text]');
    var fullPart = wrapper.querySelector('[data-full-part]');
    var moreBtn = wrapper.querySelector('[data-more-btn]');
    var showLessBtn = wrapper.querySelector('[data-show-less-btn]');

    if (!caption || !previewText || !fullPart || !moreBtn || !showLessBtn) return;

    var width = caption.offsetWidth;
    if (!width) width = 600;

    var fontStyles = {};
    var s = getComputedStyle(caption);
    var props = ['fontSize', 'fontFamily', 'lineHeight', 'fontWeight', 'letterSpacing', 'wordSpacing'];
    props.forEach(function (prop) { fontStyles[prop] = s[prop]; });

    var result = computePreview(fullText, measurer, width, fontStyles);

    if (result.needsMore) {
      previewText.textContent = result.preview + '\u2026';
      moreBtn.style.display = '';

      moreBtn.addEventListener('click', function () {
        previewText.style.display = 'none';
        fullPart.style.display = '';
        moreBtn.style.display = 'none';
        showLessBtn.style.display = '';
      });

      showLessBtn.addEventListener('click', function () {
        previewText.style.display = '';
        fullPart.style.display = 'none';
        moreBtn.style.display = '';
        showLessBtn.style.display = 'none';
      });
    }
  });

  measurer.remove();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initBookDescriptions);
} else {
  initBookDescriptions();
}

document.addEventListener('astro:page-load', initBookDescriptions);
</script>
