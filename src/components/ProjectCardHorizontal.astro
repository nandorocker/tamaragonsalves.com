---
import { images } from '../data/global';
import { loadAllTranslations, getTranslationSync } from '../utils/i18n';
import type { Language } from '../utils/i18n';

export interface Props {
  id: string;
  imageUrl: string;
  linkUrl?: string;
  linkIcon?: string;
  lang: Language;
}

const {
  id,
  imageUrl,
  linkUrl,
  linkIcon = "icon-external-link",
  lang
} = Astro.props;

const translations = await loadAllTranslations(lang, 'home');

const title = getTranslationSync(translations, `projects.${id}.title`) || `[projects.${id}.title]`;
const subtitle = getTranslationSync(translations, `projects.${id}.subtitle`) || undefined;
const description = getTranslationSync(translations, `projects.${id}.description`) || `[projects.${id}.description]`;

const linkText = linkUrl?.includes('spotify.com')
  ? getTranslationSync(translations, 'listenOnSpotify')
  : getTranslationSync(translations, 'viewProject');

function getImageAlt(id: string): string {
  switch (id) {
    case 'gender305Podcast':
      return 'Gender 305 Podcast cover image';
    default:
      return 'Project image';
  }
}

const imageAlt = getImageAlt(id);
const imagePath = `${images}/${imageUrl}`;
---

<article class="bg-white dark:bg-gray-800 rounded-lg shadow-sm px-5 py-5 hover-shift-sm h-full flex flex-row gap-4 items-start">
  <a data-fslightbox="books" href={imagePath} class="flex-shrink-0">
    <img src={imagePath} alt={imageAlt} class="w-16 h-16 rounded-md object-cover shadow-sm" loading="lazy">
  </a>
  <div class="flex-1 min-w-0 flex flex-col">
    <h5 class="mb-1 text-size-h6">{title}</h5>
    {subtitle && <p class="mb-2 text-sm dark:text-gray-300"><em>{subtitle}</em></p>}
    <p class="text-sm text-gray-700 dark:text-gray-300 flex-1">{description}</p>
    {linkUrl && (
      <a
        href={linkUrl}
        target="_blank"
        rel="noopener noreferrer"
        class={`icon-after ${linkIcon} icon-space-sm mt-3 text-sm font-semibold text-pink-700 dark:text-pink-300 hover:text-pink-900 dark:hover:text-pink-100 self-start`}
      >
        {linkText}
      </a>
    )}
  </div>
</article>
