---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { useTranslations, getLangFromUrl } from '../utils/i18n';

export interface Props {
  img: ImageMetadata;
  altKey: string;
  fslightboxGroup: string;
  gridClass?: string;
  imgClass?: string;
}

const { img, altKey, fslightboxGroup, gridClass, imgClass = "" } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const alt = t(altKey as any);

const lightboxWidth = Math.min(1200, img.width || 1200);
const lightboxImg = await getImage({
  src: img,
  format: 'webp',
  width: lightboxWidth,
  quality: 92,
});
---

<a
  data-fslightbox={fslightboxGroup}
  href={lightboxImg.src}
  {...(gridClass ? { class: gridClass } : {})}
>
  <Image
    src={img}
    alt={alt}
    inferSize
    widths={[400, 800, 1200]}
    sizes="(min-width: 768px) 50vw, 100vw"
    format="webp"
    quality={90}
    loading="lazy"
    class={`rounded-md drop-shadow-md hover-shift-sm ${imgClass}`}
  />
</a>
