---
// Header component for site navigation
// Converted from 11ty nav.njk include
import { useTranslations } from '../utils/i18n';
import { loadTranslations, getTranslationSync } from '../utils/i18n';
import type { Language } from '../utils/i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

export interface Props {
  lang: 'en' | 'pt';
  pageTheme?: 'yellow' | 'white' | 'soap' | 'violet';
}

const { lang, pageTheme = 'white' } = Astro.props;

// Map page themes to header colors
const themeColors = {
  yellow: 'bg-mustard-50/0 dark:bg-gray-800/0 text-indigo-900 dark:text-indigo-300',
  white: 'bg-white/0 dark:bg-gray-800/0 text-gray-900 dark:text-gray-100',
  soap: 'bg-soap-50/0 dark:bg-gray-700/0 text-gray-900 dark:text-gray-100',
  violet: 'bg-violet-50/0 dark:bg-gray-700/0 text-violet-900 dark:text-pink-300'
};

const headerColorClass = themeColors[pageTheme];
const t = useTranslations(lang);

// Load global translations for UI strings
const globalTranslations = await loadTranslations(lang as Language);

// Generate language-aware URLs
const langPrefix = lang === 'en' ? '/en' : `/${lang}`;
const siteTitle = getTranslationSync(globalTranslations, 'siteTitle');
---

<header id="top_nav" class={`top-nav fixed w-full top-0 z-10 backdrop-blur-sm border-b border-[#F8DEA0] ${headerColorClass}`}>
    <div class="flex flex-col md:block w-full">

        <!-- Mobile top bar: hamburger toggle (always visible on mobile) -->
        <div class="flex items-center justify-between md:hidden px-5 pt-2.5 pb-2">
            <button id="menu_toggle" type="button"
                class="inline-flex items-center justify-center py-2 rounded-md">
                <span class="sr-only">Open main menu</span>
                <svg id="menu_icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
        </div>

        <!-- Navigation: 3-column grid on desktop, collapsible flex-col on mobile -->
        <nav id="menu"
            class="hidden flex-col md:grid md:grid-cols-[1fr_auto_1fr] md:items-center md:h-20 w-full px-5 md:px-6 lg:px-10 max-md:space-y-3 max-md:pb-5">

            <!-- Left: Site name (desktop only) -->
            <a href={`${langPrefix}/`}
                class="nav-site-name hidden md:block text-left"
                set:html={siteTitle.split(' ').join('<br>')} />

            <!-- Center: Main navigation links -->
            <div class="flex flex-col md:flex-row md:items-center md:space-x-8 lg:space-x-10 max-md:space-y-3">
                <a href={`${langPrefix}/`} class="md:text-base md:uppercase md:tracking-wide">{t('navAbout')}</a>
                <a href={`${langPrefix}/publications`} class="md:text-base md:uppercase md:tracking-wide">{t('navPublications')}</a>
                <a href={`${langPrefix}/speaking`} class="md:text-base md:uppercase md:tracking-wide">{t('navSpeaking')}</a>
                <a href={`${langPrefix}/services`} class="md:text-base md:uppercase md:tracking-wide">{t('navServices')}</a>
                <a href={`${langPrefix}/#contact-me`} class="md:text-base md:uppercase md:tracking-wide">{t('navContact')}</a>
            </div>

            <!-- Right: Controls -->
            <div class="flex items-center space-x-4 max-md:mt-4 md:justify-end">
                <LanguageSwitcher lang={lang} />

                <!-- Dark mode toggle (mobile only) -->
                <div class="flex items-center md:hidden">
                    <button id="theme-toggle" type="button"
                        class="inline-flex items-center justify-center rounded-md text-pink-700 hover:text-pink-900 dark:text-pink-300 dark:hover:text-pink-100 transition-colors duration-200"
                        aria-label="Toggle dark mode">
                        <!-- Sun icon - visible in dark mode -->
                        <svg id="sun-icon" class="h-5 w-5 hidden" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
                                clip-rule="evenodd" />
                        </svg>
                        <!-- Moon icon - visible in light mode -->
                        <svg id="moon-icon" class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
                        </svg>
                    </button>
                </div>
            </div>
        </nav>
    </div>
</header>