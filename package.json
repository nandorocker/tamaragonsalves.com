{
  "name": "tamaragonsalves.com",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "bun@1.3.4",
  "description": "Tamara Gonsalves Website - Astro Site",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && (find .vercel/output/static/_astro dist/_astro -type f \\( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' \\) -delete 2>/dev/null || true)",
    "preview": "astro preview",
    "astro": "astro",
    "start": "astro dev",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "astro",
    "website",
    "academic",
    "portfolio"
  ],
  "author": "Nando Rossi",
  "license": "ISC",
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^8.2.11",
    "@vercel/postgres": "^0.10.0",
    "astro": "^5.18.1",
    "resend": "^6.14.0",
    "tailwind-fontawesome": "^0.7.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
